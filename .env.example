# Required: OpenAI API key — used ONLY for chat completions (gpt-4o-mini).
# Embeddings are generated locally via ONNX — no API key needed for search or ingestion.
OPENAI_API_KEY=sk-...

# Required for deployment to Harper Fabric (npm run deploy)
# Sign up free at https://fabric.harper.fast/
CLI_TARGET_USERNAME=your-username
CLI_TARGET_PASSWORD=your-password
CLI_TARGET=https://your-cluster.harperfabric.com
